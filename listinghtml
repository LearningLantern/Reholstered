<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Listing — Reholstered Marketplace</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;900&family=Barlow:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#0a0b0d;--bg2:#111318;--bg3:#181c22;--bg4:#1f242d;
  --border:rgba(255,255,255,0.07);--border2:rgba(255,255,255,0.13);
  --accent:#c8973a;--accent2:#e8b55a;--accent-dim:rgba(200,151,58,0.12);
  --text:#e8e6e0;--text2:#9a9690;--text3:#5c5a56;
  --font-head:'Barlow Condensed',sans-serif;--font-body:'Barlow',sans-serif;
  --danger:#e05252;--success:#5ab46a;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--bg);color:var(--text);font-family:var(--font-body);font-size:15px;min-height:100vh;}
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");pointer-events:none;z-index:0;opacity:0.4;}

nav{position:sticky;top:0;z-index:100;background:rgba(10,11,13,0.92);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);padding:0 2rem;display:flex;align-items:center;justify-content:space-between;height:60px;}
.logo{font-family:var(--font-head);font-size:26px;font-weight:900;letter-spacing:0.05em;color:var(--text);text-decoration:none;display:flex;align-items:center;gap:10px;}

.nav-links{display:flex;gap:2rem;list-style:none;}
.nav-links a{color:var(--text2);text-decoration:none;font-size:13px;letter-spacing:0.08em;text-transform:uppercase;font-weight:500;transition:color 0.2s;}
.nav-links a:hover{color:var(--accent);}
.nav-btn{background:var(--accent);color:#0a0b0d;border:none;padding:8px 18px;font-family:var(--font-head);font-size:14px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;cursor:pointer;text-decoration:none;display:inline-block;}

.breadcrumb{max-width:1100px;margin:0 auto;padding:1rem 2rem .5rem;font-size:12px;color:var(--text3);position:relative;z-index:1;letter-spacing:0.04em;}
.breadcrumb a{color:var(--accent);text-decoration:none;}

.main{max-width:1100px;margin:0 auto;padding:0 2rem 4rem;display:grid;grid-template-columns:1fr 360px;gap:2rem;position:relative;z-index:1;}

/* PHOTOS */
.photo-gallery{position:sticky;top:76px;align-self:start;}
.main-photo{width:100%;aspect-ratio:4/3;object-fit:cover;background:var(--bg2);border:1px solid var(--border);cursor:zoom-in;display:block;}
.main-photo-placeholder{width:100%;aspect-ratio:4/3;background:var(--bg2);border:1px solid var(--border);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;color:var(--text3);font-size:12px;letter-spacing:0.06em;text-transform:uppercase;}
.photo-thumbs{display:flex;gap:4px;flex-wrap:wrap;margin-top:4px;}
.photo-thumb-sm{width:64px;height:64px;object-fit:cover;border:1px solid var(--border);cursor:pointer;transition:border-color .15s;opacity:.6;}
.photo-thumb-sm.active,.photo-thumb-sm:hover{border-color:var(--accent);opacity:1;}

/* DETAIL */
.listing-brand{font-family:var(--font-head);font-size:11px;font-weight:600;letter-spacing:0.15em;text-transform:uppercase;color:var(--accent);margin-bottom:.25rem;}
.listing-title{font-family:var(--font-head);font-size:clamp(24px,4vw,40px);font-weight:900;line-height:1;letter-spacing:0.02em;text-transform:uppercase;margin-bottom:.75rem;}
.listing-meta{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:1.25rem;}
.meta-tag{font-size:11px;font-weight:600;padding:3px 10px;border:1px solid var(--border2);color:var(--text2);letter-spacing:0.06em;text-transform:uppercase;}
.listing-price-row{display:flex;align-items:baseline;gap:12px;margin-bottom:1rem;}
.listing-price{font-family:var(--font-head);font-size:48px;font-weight:900;color:var(--accent);line-height:1;}
.listing-shipping{font-size:13px;color:var(--text2);}
.cond-badge{font-size:10px;font-weight:700;padding:3px 10px;border:1px solid;text-transform:uppercase;letter-spacing:0.08em;}
.cond-new_never_used{color:var(--accent);border-color:rgba(200,151,58,0.4);}
.cond-like_new{color:var(--success);border-color:rgba(90,180,106,0.4);}
.cond-good{color:#6a9de0;border-color:rgba(106,157,224,0.4);}
.cond-fair{color:#c8a03c;border-color:rgba(200,160,60,0.4);}
.cond-poor{color:var(--danger);border-color:rgba(224,82,82,0.4);}

.divider{border:none;border-top:1px solid var(--border);margin:1.25rem 0;}
.section-label{font-size:11px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(--text3);margin-bottom:.5rem;}
.description{font-size:14px;line-height:1.7;color:var(--text2);white-space:pre-line;}

.specs-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--border);}
.spec{background:var(--bg2);padding:10px 12px;}
.spec-label{font-size:10px;color:var(--text3);font-weight:600;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:3px;}
.spec-value{font-size:14px;font-weight:500;}

/* SELLER */
.seller-card{background:var(--bg2);border:1px solid var(--border2);padding:1.25rem;margin-bottom:1rem;}
.seller-header{display:flex;align-items:center;gap:12px;margin-bottom:.75rem;}
.seller-avatar{width:44px;height:44px;background:var(--accent-dim);border:1px solid rgba(200,151,58,0.3);display:flex;align-items:center;justify-content:center;font-family:var(--font-head);font-size:18px;font-weight:900;color:var(--accent);flex-shrink:0;}
.seller-name{font-weight:500;font-size:15px;}
.seller-location{font-size:12px;color:var(--text3);margin-top:2px;letter-spacing:0.04em;}

/* CONTACT */
.contact-section{background:var(--bg2);border:1px solid var(--border2);padding:1.25rem;}
.contact-title{font-family:var(--font-head);font-size:18px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:1rem;}
.btn-contact{width:100%;padding:13px;background:var(--accent);color:#0a0b0d;border:none;font-family:var(--font-head);font-size:16px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;cursor:pointer;transition:background .2s;margin-bottom:.75rem;display:block;text-align:center;}
.btn-contact:hover{background:var(--accent2);}
.btn-contact:disabled{background:var(--bg4);color:var(--text3);cursor:not-allowed;}
.signin-prompt{font-size:12px;color:var(--text3);text-align:center;letter-spacing:0.02em;}
.signin-prompt a{color:var(--accent);text-decoration:none;}

/* MESSAGES */
.message-thread{margin-top:.75rem;}
.messages-list{max-height:280px;overflow-y:auto;display:flex;flex-direction:column;gap:8px;margin-bottom:.75rem;padding-right:4px;}
.message-bubble{max-width:85%;padding:10px 12px;font-size:13px;line-height:1.5;}
.message-bubble.mine{background:var(--accent-dim);border:1px solid rgba(200,151,58,0.2);align-self:flex-end;}
.message-bubble.theirs{background:var(--bg3);border:1px solid var(--border2);align-self:flex-start;}
.message-time{font-size:10px;opacity:.5;margin-top:3px;letter-spacing:0.04em;}
.message-input-row{display:flex;gap:6px;}
.message-input{flex:1;padding:10px 12px;border:1px solid var(--border2);background:var(--bg3);color:var(--text);font-size:13px;font-family:var(--font-body);resize:none;height:42px;transition:border-color .2s;}
.message-input:focus{outline:none;border-color:var(--accent);}
.btn-send{padding:10px 16px;background:var(--accent);color:#0a0b0d;border:none;font-family:var(--font-head);font-size:13px;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;cursor:pointer;transition:background .2s;white-space:nowrap;}
.btn-send:hover{background:var(--accent2);}
.btn-send:disabled{background:var(--bg4);color:var(--text3);cursor:not-allowed;}

.sold-overlay{background:var(--bg3);border:1px solid var(--border2);color:var(--text3);text-align:center;padding:12px;font-family:var(--font-head);font-size:16px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:.75rem;}

.lightbox{display:none;position:fixed;inset:0;background:rgba(0,0,0,.95);z-index:1000;align-items:center;justify-content:center;cursor:zoom-out;}
.lightbox.open{display:flex;}
.lightbox img{max-width:90vw;max-height:90vh;object-fit:contain;}
.lightbox-close{position:absolute;top:1rem;right:1rem;background:none;border:none;color:var(--text);font-size:32px;cursor:pointer;line-height:1;}

.not-found{text-align:center;padding:6rem 2rem;color:var(--text3);position:relative;z-index:1;}
.not-found h2{font-family:var(--font-head);font-size:28px;font-weight:900;text-transform:uppercase;color:var(--text2);margin-bottom:.5rem;}

@media(max-width:768px){
  .main{grid-template-columns:1fr;}
  .photo-gallery{position:static;}
  .listing-title{font-size:28px;}
  .listing-price{font-size:36px;}
}
@media(max-width:600px){
  .main{padding:0 1rem 3rem;}
  .breadcrumb{padding:.75rem 1rem .25rem;}
}
</style>
</head>
<body>
<nav>
  <a href="/index.html" class="logo">
    REHOLSTERED
  </a>
  <ul class="nav-links">
    <li><a href="/index.html">Find Holsters</a></li>
    <li><a href="/marketplace.html">Marketplace</a></li>
  </ul>
  <a href="/account.html" class="nav-btn" id="nav-account">Sign In</a>
</nav>

<div class="breadcrumb"><a href="/marketplace.html">← Marketplace</a></div>

<div class="main" id="main-content" style="display:none">
  <div class="photo-gallery">
    <div id="main-photo-container"></div>
    <div class="photo-thumbs" id="photo-thumbs"></div>
  </div>
  <div class="listing-detail">
    <div class="listing-brand" id="l-brand"></div>
    <h1 class="listing-title" id="l-title"></h1>
    <div class="listing-meta" id="l-meta"></div>
    <div class="listing-price-row">
      <div class="listing-price" id="l-price"></div>
      <div class="listing-shipping" id="l-shipping"></div>
    </div>
    <div class="seller-card" id="seller-card">
      <div class="seller-header">
        <div class="seller-avatar" id="seller-avatar"></div>
        <div><div class="seller-name" id="seller-name"></div><div class="seller-location" id="seller-location"></div></div>
      </div>
    </div>
    <div class="contact-section" id="contact-section">
      <div class="contact-title">Contact Seller</div>
      <div id="contact-body"></div>
    </div>
    <hr class="divider">
    <div id="l-description-section" style="display:none">
      <div class="section-label">Description</div>
      <div class="description" id="l-description"></div>
      <hr class="divider">
    </div>
    <div class="section-label">Specifications</div>
    <div class="specs-grid" id="l-specs"></div>
    <div style="margin-top:1.5rem;font-size:11px;color:var(--text3);letter-spacing:0.04em">
      ★ FOUNDING SELLER — FREE LISTING THROUGH SEPT 1, 2026
    </div>
  </div>
</div>

<div id="not-found" class="not-found" style="display:none">
  <h2>Listing Not Found</h2>
  <p>This listing may have been removed or sold.</p>
  <a href="/marketplace.html" style="color:var(--accent);text-decoration:none;font-family:var(--font-head);font-size:13px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;margin-top:1rem;display:inline-block">← Back to Marketplace</a>
</div>

<div class="lightbox" id="lightbox" onclick="closeLightbox()">
  <button class="lightbox-close" onclick="closeLightbox()">×</button>
  <img id="lightbox-img" src="" alt="Full size photo">
</div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script>
const SUPABASE_URL='https://crkjxsexcnjzlzwfxxfz.supabase.co';
const SUPABASE_KEY='eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImNya2p4c2V4Y25qemx6d2Z4eGZ6Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzc0NDUxOTgsImV4cCI6MjA5MzAyMTE5OH0.6JAN9AH6a4RF4nMugqOREkL4sHulE3vhyk3zyQm74OI';
const db=window.supabase.createClient(SUPABASE_URL,SUPABASE_KEY);

let currentUser=null,listing=null,threadId=null,messageInterval=null;

const conditionLabels={new_never_used:'New, Never Used',like_new:'Like New',good:'Good',fair:'Fair',poor:'Poor'};
const carryLabels={iwb:'IWB',aiwb:'AIWB',owb:'OWB','owb-paddle':'OWB Paddle',duty:'Duty',shoulder:'Shoulder',ankle:'Ankle',offbody:'Off-Body'};

async function init() {
  const params=new URLSearchParams(window.location.search);
  const listingId=params.get('id');
  if(!listingId){showNotFound();return;}
  const {data:{user}}=await db.auth.getUser();
  currentUser=user;
  if(user){document.getElementById('nav-account').textContent='My Account';}
  await loadListing(listingId);
}

async function loadListing(id) {
  const {data,error}=await db.from('listings').select('*,listing_images(url,position),profiles(username,full_name,location)').eq('id',id).single();
  if(error||!data){showNotFound();return;}
  listing=data;
  document.title=`${data.title} — Reholstered`;
  renderListing(data);
  document.getElementById('main-content').style.display='grid';
  db.from('listings').update({view_count:(data.view_count||0)+1}).eq('id',id);
  if(currentUser&&currentUser.id!==data.seller_id) await loadOrCreateThread(id,data.seller_id);
}

function renderListing(l) {
  document.getElementById('l-brand').textContent=l.brand||'';
  document.getElementById('l-title').textContent=l.title;
  document.getElementById('l-price').textContent=`$${parseFloat(l.price).toFixed(2)}`;
  const shipping=l.shipping_option==='free'?'Free shipping':l.shipping_option==='paid'?`+$${parseFloat(l.shipping_price||0).toFixed(2)} shipping`:'Local pickup only';
  document.getElementById('l-shipping').textContent=shipping;

  const metaTags=[];
  if(l.condition) metaTags.push(`<span class="meta-tag cond-badge cond-${l.condition}">${conditionLabels[l.condition]}</span>`);
  if(l.carry_type) metaTags.push(`<span class="meta-tag">${carryLabels[l.carry_type]||l.carry_type}</span>`);
  if(l.gun_model) metaTags.push(`<span class="meta-tag">${l.gun_model}</span>`);
  if(l.ships_from) metaTags.push(`<span class="meta-tag">📍 ${l.ships_from}</span>`);
  document.getElementById('l-meta').innerHTML=metaTags.join('');

  const images=(l.listing_images||[]).sort((a,b)=>a.position-b.position);
  const photoContainer=document.getElementById('main-photo-container');
  const thumbsContainer=document.getElementById('photo-thumbs');
  if(images.length) {
    photoContainer.innerHTML=`<img class="main-photo" id="main-photo" src="${images[0].url}" alt="${l.title}" onclick="openLightbox('${images[0].url}')">`;
    thumbsContainer.innerHTML=images.map((img,i)=>`<img class="photo-thumb-sm ${i===0?'active':''}" src="${img.url}" alt="Photo ${i+1}" onclick="switchPhoto('${img.url}',this)">`).join('');
  } else {
    photoContainer.innerHTML=`<div class="main-photo-placeholder"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" style="opacity:.3"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg><span>No photos</span></div>`;
  }

  const profile=l.profiles||{};
  const name=profile.full_name||profile.username||'Seller';
  const initials=name.split(' ').map(n=>n[0]).join('').toUpperCase().slice(0,2);
  document.getElementById('seller-avatar').textContent=initials;
  document.getElementById('seller-name').textContent=name;
  document.getElementById('seller-location').textContent=profile.location||l.ships_from||'';

  if(l.description) { document.getElementById('l-description').textContent=l.description; document.getElementById('l-description-section').style.display='block'; }

  const specs=[
    {label:'Brand',value:l.brand},{label:'Gun Model',value:l.gun_model},
    {label:'Carry Type',value:carryLabels[l.carry_type]||l.carry_type},
    {label:'Condition',value:conditionLabels[l.condition]||l.condition},
    {label:'Material',value:l.material},
    {label:'Light Compatible',value:l.light_compatible},
    {label:'Optic Compatible',value:l.optic_compatible},
  ].filter(s=>s.value);
  document.getElementById('l-specs').innerHTML=specs.map(s=>`<div class="spec"><div class="spec-label">${s.label}</div><div class="spec-value">${s.value}</div></div>`).join('');

  renderContactSection(l);
}

function renderContactSection(l) {
  const contactBody=document.getElementById('contact-body');
  if(l.status==='sold') { contactBody.innerHTML='<div class="sold-overlay">This item has been sold</div>'; return; }
  if(!currentUser) {
    contactBody.innerHTML=`<button class="btn-contact" onclick="window.location.href='/account.html'">Sign In to Contact Seller</button><div class="signin-prompt">No account? <a href="/account.html">Create one free</a></div>`;
    return;
  }
  if(currentUser.id===l.seller_id) {
    contactBody.innerHTML=`<div style="text-align:center;color:var(--text3);font-size:13px;padding:.5rem;letter-spacing:0.04em">This is your listing. <a href="/account.html" style="color:var(--accent);text-decoration:none;font-weight:600">Manage it here.</a></div>`;
    return;
  }
  contactBody.innerHTML=`<div class="message-thread"><div class="messages-list" id="messages-list"><div style="text-align:center;color:var(--text3);font-size:12px;padding:1rem;letter-spacing:0.04em">Loading messages...</div></div><div class="message-input-row"><textarea class="message-input" id="message-input" placeholder="Ask about condition, shipping, or make an offer..." onkeydown="handleMessageKey(event)"></textarea><button class="btn-send" onclick="sendMessage()">Send</button></div></div>`;
}

async function loadOrCreateThread(listingId,sellerId) {
  const {data:existing}=await db.from('message_threads').select('id').eq('listing_id',listingId).eq('buyer_id',currentUser.id).single();
  if(existing) { threadId=existing.id; await loadMessages(); messageInterval=setInterval(loadMessages,5000); }
  else { threadId=null; renderNoMessages(); }
}

function renderNoMessages() {
  const list=document.getElementById('messages-list');
  if(list) list.innerHTML='<div style="text-align:center;color:var(--text3);font-size:12px;padding:1rem;letter-spacing:0.04em">Send a message to start a conversation.</div>';
}

async function loadMessages() {
  if(!threadId) return;
  const list=document.getElementById('messages-list');
  if(!list) return;
  const {data,error}=await db.from('messages').select('*').eq('thread_id',threadId).order('created_at',{ascending:true});
  if(error||!data) return;
  if(!data.length){renderNoMessages();return;}
  list.innerHTML=data.map(msg=>{
    const mine=msg.sender_id===currentUser.id;
    const time=new Date(msg.created_at).toLocaleString('en-US',{month:'short',day:'numeric',hour:'numeric',minute:'2-digit'});
    return `<div style="display:flex;flex-direction:column;align-items:${mine?'flex-end':'flex-start'}"><div class="message-bubble ${mine?'mine':'theirs'}">${msg.body}<div class="message-time">${time}</div></div></div>`;
  }).join('');
  list.scrollTop=list.scrollHeight;
  db.from('messages').update({read:true}).eq('thread_id',threadId).neq('sender_id',currentUser.id);
}

async function sendMessage() {
  const input=document.getElementById('message-input');
  const btn=document.querySelector('.btn-send');
  const body=input.value.trim();
  if(!body||!listing) return;
  btn.disabled=true; input.disabled=true;
  if(!threadId) {
    const {data:thread,error}=await db.from('message_threads').insert({listing_id:listing.id,buyer_id:currentUser.id,seller_id:listing.seller_id}).select().single();
    if(error||!thread){
      console.error('Thread error:',error);
      btn.disabled=false;input.disabled=false;
      alert('Could not start conversation: ' + (error?.message || 'Please try again.'));
      return;
    }
    threadId=thread.id; messageInterval=setInterval(loadMessages,5000);
  }
  const {error}=await db.from('messages').insert({thread_id:threadId,sender_id:currentUser.id,body});
  if(!error){input.value='';await loadMessages();}
  btn.disabled=false; input.disabled=false; input.focus();
}

function handleMessageKey(e){if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendMessage();}}
function switchPhoto(url,thumbEl){document.getElementById('main-photo').src=url;document.getElementById('main-photo').onclick=()=>openLightbox(url);document.querySelectorAll('.photo-thumb-sm').forEach(t=>t.classList.remove('active'));thumbEl.classList.add('active');}
function openLightbox(url){document.getElementById('lightbox-img').src=url;document.getElementById('lightbox').classList.add('open');}
function closeLightbox(){document.getElementById('lightbox').classList.remove('open');}
function showNotFound(){document.getElementById('not-found').style.display='block';}
document.addEventListener('keydown',e=>{if(e.key==='Escape')closeLightbox();});
window.addEventListener('beforeunload',()=>{if(messageInterval)clearInterval(messageInterval);});
init();
</script>
</body>
</html>
